{
  "name": "live-check-in-web",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "cd ../.. && npm run build --workspace packages/shared",
    "dev": "vite --host 0.0.0.0",
    "prebuild": "cd ../.. && npm run build --workspace packages/shared",
    "build": "tsc -p tsconfig.json && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "pretest": "cd ../.. && npm run build --workspace packages/shared",
    "test": "vitest run",
    "pretypecheck": "cd ../.. && npm run build --workspace packages/shared",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@live-check-in-demo/shared": "file:../../packages/shared",
    "ky": "^1.7.5",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "jsdom": "^26.1.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.2.4"
  }
}
